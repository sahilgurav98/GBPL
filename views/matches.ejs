<%- include('partials/head', { pageTitle: `${t.siteName} | ${t.navMatches}` }) %>
<%- include('partials/navbar', { currentPath, user, isAdmin }) %>

<section class="hero-section">
    <div class="container">
        <div class="hero-shell">
            <div class="hero-card">
                <span class="hero-eyebrow"><%= t.matchCenter %></span>
                <h1><%= t.allMatches %></h1>
                <p class="lead text-white-50 mb-0"><%= t.matchCenterText %></p>
            </div>
            <div class="hero-side">
                <div class="glass-card">
                    <span class="section-kicker"><%= t.latestResults %></span>
                    <h3 class="mb-2"><%= matches[0] ? matches[0].displayResult : t.noMatches %></h3>
                    <p class="text-white-50 mb-0"><%= matches[0] ? `${matches[0].teamA} vs ${matches[0].teamB}` : '' %></p>
                </div>
                <div class="glass-card">
                    <span class="section-kicker"><%= t.quickOverview %></span>
                    <h3 class="mb-2"><%= matches.length %> <%= t.totalMatches %></h3>
                    <p class="text-white-50 mb-0"><%= t.heroText %></p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="page-section">
    <div class="container">
        <div class="section-heading">
            <div>
                <span class="section-kicker"><%= t.latestResults %></span>
                <h2><%= t.allMatches %></h2>
            </div>
        </div>

        <% if (!matches.length) { %>
            <div class="summary-card"><p class="mb-0 muted-copy"><%= t.noMatches %></p></div>
        <% } else { %>
            <div class="dual-grid">
                <% matches.forEach(match => { %>
                    <article class="match-card">
                        <div class="pill-row">
                            <% if (match.season) { %><span class="soft-pill"><%= t.season %>: <%= match.season %></span><% } %>
                            <span class="soft-pill"><%= new Date(match.date).toLocaleDateString('en-IN') %></span>
                            <% if (match.venue) { %><span class="soft-pill"><%= t.venue %>: <%= match.venue %></span><% } %>
                        </div>
                        <h3 class="h4"><%= match.teamA %> vs <%= match.teamB %></h3>
                        <div class="score-row">
                            <div class="score-box">
                                <span class="muted-copy"><%= match.teamA %></span>
                                <strong><%= match.scoreA || '--' %></strong>
                            </div>
                            <div class="score-box">
                                <span class="muted-copy"><%= match.teamB %></span>
                                <strong><%= match.scoreB || '--' %></strong>
                            </div>
                        </div>
                        <div class="pill-row">
                            <span class="stat-pill"><%= match.displayResult %></span>
                        </div>
                        <% if (match.displayDescription) { %>
                            <p class="card-copy mb-0"><strong><%= t.highlights %>:</strong> <%= match.displayDescription %></p>
                        <% } %>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </div>
</section>
<%- include('partials/footer') %>
