<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GBPL - Matches</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🏏 GBPL</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav me-auto">
                    <a class="nav-link" href="/">News & Blogs</a>
                    <a class="nav-link active" href="/matches">Matches</a>
                    <a class="nav-link" href="/stats">Player Stats</a>
                </div>
                <div class="ms-auto mt-2 mt-lg-0 d-flex gap-2">
                    <% if(user) { %>
                        <% if(isAdmin) { %> <a href="/admin" class="btn btn-warning btn-sm">Admin Panel</a> <% } %>
                        <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
                    <% } else { %>
                        <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        <h3 class="mb-4 border-bottom pb-2">🏏 Match Results</h3>
        <div class="row mb-5">
            <% if(matches.length === 0) { %> <p class="text-muted">No matches played yet.</p> <% } %>
            <% matches.forEach(match => { %>
                <div class="col-md-6 mb-4">
                    <div class="card border-primary shadow-sm h-100">
                        <div class="card-header bg-primary text-white d-flex justify-content-between flex-wrap">
                            <span><%= match.season %></span>
                            <span><%= new Date(match.date).toLocaleDateString() %></span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title text-center"><%= match.teamA %> vs <%= match.teamB %></h5>
                            <div class="d-flex justify-content-between fw-bold mb-3 px-1 px-md-3 text-break">
                                <span><%= match.scoreA %></span>
                                <span><%= match.scoreB %></span>
                            </div>
                            <p class="alert alert-light border text-center fw-bold"><%= match.result %></p>
                            <hr>
                            <p class="card-text text-muted small"><strong>Highlights:</strong> <%= match.description %></p>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>