<%- include('partials/head', { pageTitle: `${t.siteName} | ${t.navStats}` }) %>
<%- include('partials/navbar', { currentPath, user, isAdmin }) %>

<section class="hero-section">
    <div class="container">
        <div class="hero-shell">
            <div class="hero-card">
                <span class="hero-eyebrow"><%= t.playerStats %></span>
                <h1><%= t.playerLeaders %></h1>
                <p class="lead text-white-50 mb-0"><%= t.playerStatsText %></p>
            </div>
            <div class="hero-side">
                <div class="glass-card">
                    <span class="section-kicker"><%= t.topRunScorer %></span>
                    <h3 class="mb-2"><%= players[0] ? players[0].name : '--' %></h3>
                    <p class="text-white-50 mb-0"><%= players[0] ? `${players[0].runs} ${t.runs}` : t.noPlayers %></p>
                </div>
                <div class="glass-card">
                    <span class="section-kicker"><%= t.topWicketTaker %></span>
                    <h3 class="mb-2"><%= topWicketTakers[0] ? topWicketTakers[0].name : '--' %></h3>
                    <p class="text-white-50 mb-0"><%= topWicketTakers[0] ? `${topWicketTakers[0].wickets} ${t.wickets}` : t.noPlayers %></p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="page-section">
    <div class="container">
        <div class="dual-grid mb-4">
            <div class="leader-card">
                <span class="section-kicker"><%= t.topRunScorer %></span>
                <h3><%= players[0] ? players[0].name : '--' %></h3>
                <div class="leader-value"><%= players[0] ? players[0].runs : 0 %></div>
                <p class="card-copy mb-0"><%= t.runs %></p>
            </div>
            <div class="leader-card">
                <span class="section-kicker"><%= t.topWicketTaker %></span>
                <h3><%= topWicketTakers[0] ? topWicketTakers[0].name : '--' %></h3>
                <div class="leader-value"><%= topWicketTakers[0] ? topWicketTakers[0].wickets : 0 %></div>
                <p class="card-copy mb-0"><%= t.wickets %></p>
            </div>
        </div>

        <div class="section-heading">
            <div>
                <span class="section-kicker"><%= t.statsSnapshot %></span>
                <h2><%= t.playerStats %></h2>
            </div>
        </div>
        <div class="table-shell">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th><%= t.playerName %></th>
                            <th><%= t.matchesPlayed %></th>
                            <th><%= t.runs %></th>
                            <th><%= t.wickets %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!players.length) { %>
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4"><%= t.noPlayers %></td>
                            </tr>
                        <% } %>
                        <% players.forEach((player, index) => { %>
                            <tr>
                                <td><strong><%= index + 1 %></strong></td>
                                <td><strong><%= player.name %></strong></td>
                                <td><%= player.matchesPlayed %></td>
                                <td class="text-primary fw-bold"><%= player.runs %></td>
                                <td class="text-danger fw-bold"><%= player.wickets %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
<%- include('partials/footer') %>
