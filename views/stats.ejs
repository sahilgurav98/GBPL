<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GBPL - Player Stats</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🏏 GBPL</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav me-auto">
                    <a class="nav-link" href="/">News & Blogs</a>
                    <a class="nav-link" href="/matches">Matches</a>
                    <a class="nav-link active" href="/stats">Player Stats</a>
                </div>
                <div class="ms-auto mt-2 mt-lg-0 d-flex gap-2">
                    <% if(user) { %>
                        <% if(isAdmin) { %> <a href="/admin" class="btn btn-warning btn-sm">Admin Panel</a> <% } %>
                        <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
                    <% } else { %>
                        <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        <h3 class="mb-4 border-bottom pb-2">🏆 Player Leaderboard</h3>
        <div class="table-responsive bg-white shadow-sm p-2 p-md-3 mb-5 rounded">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Player Name</th>
                        <th>Matches</th>
                        <th>Runs</th>
                        <th>Wickets</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(players.length === 0) { %> 
                        <tr><td colspan="4" class="text-center text-muted">No players added yet.</td></tr> 
                    <% } %>
                    <% players.forEach(player => { %>
                        <tr>
                            <td class="fw-bold text-nowrap"><%= player.name %></td>
                            <td><%= player.matchesPlayed %></td>
                            <td class="text-primary fw-bold"><%= player.runs %></td>
                            <td class="text-danger fw-bold"><%= player.wickets %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>