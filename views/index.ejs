<%- include('partials/head', { pageTitle: `${t.siteName} | ${t.navHome}` }) %>
<%- include('partials/navbar', { currentPath, user, isAdmin }) %>

<section class="hero-section">
    <div class="container">
        <div class="hero-shell">
            <div class="hero-card">
                <span class="hero-eyebrow"><%= t.heroEyebrow %></span>
                <h1><%= t.heroTitle %></h1>
                <p class="lead text-white-50 mb-4"><%= t.heroText %></p>
                <div class="hero-actions">
                    <a href="/matches" class="btn btn-warning btn-lg rounded-pill px-4"><%= t.heroPrimary %></a>
                    <a href="/stats" class="btn btn-outline-light btn-lg rounded-pill px-4"><%= t.heroSecondary %></a>
                </div>
                <div class="metric-grid">
                    <div class="metric-item">
                        <span><%= t.totalPlayers %></span>
                        <strong><%= counts.players %></strong>
                    </div>
                    <div class="metric-item">
                        <span><%= t.totalMatches %></span>
                        <strong><%= counts.matches %></strong>
                    </div>
                    <div class="metric-item">
                        <span><%= t.publishedStories %></span>
                        <strong><%= counts.blogs %></strong>
                    </div>
                </div>
            </div>
            <div class="hero-side">
                <div class="glass-card">
                    <span class="section-kicker"><%= t.matchCenter %></span>
                    <h3 class="mb-2"><%= matches[0] ? `${matches[0].teamA} vs ${matches[0].teamB}` : t.latestResults %></h3>
                    <p class="text-white-50 mb-0"><%= matches[0] ? matches[0].displayResult : t.noMatches %></p>
                </div>
                <div class="glass-card">
                    <span class="section-kicker"><%= t.playerLeaders %></span>
                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                        <div>
                            <p class="text-white-50 mb-2"><%= t.topRunScorer %></p>
                            <h4 class="mb-0"><%= topRunScorer ? topRunScorer.name : '--' %></h4>
                        </div>
                        <div class="text-end">
                            <p class="text-white-50 mb-2"><%= t.runs %></p>
                            <h3 class="mb-0"><%= topRunScorer ? topRunScorer.runs : 0 %></h3>
                        </div>
                    </div>
                    <hr class="border-light opacity-25">
                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                        <div>
                            <p class="text-white-50 mb-2"><%= t.topWicketTaker %></p>
                            <h4 class="mb-0"><%= topWicketTaker ? topWicketTaker.name : '--' %></h4>
                        </div>
                        <div class="text-end">
                            <p class="text-white-50 mb-2"><%= t.wickets %></p>
                            <h3 class="mb-0"><%= topWicketTaker ? topWicketTaker.wickets : 0 %></h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="page-section">
    <div class="container">
        <div class="dual-grid mb-4">
            <div class="summary-card">
                <span class="section-kicker"><%= t.matchCenter %></span>
                <h3><%= t.matchCenterText %></h3>
                <p class="card-copy mb-0"><%= t.quickOverview %></p>
            </div>
            <div class="summary-card">
                <span class="section-kicker"><%= t.leaderboard %></span>
                <h3><%= t.leaderboardText %></h3>
                <p class="card-copy mb-0"><%= t.playerStatsText %></p>
            </div>
        </div>

        <div class="section-heading">
            <div>
                <span class="section-kicker"><%= t.leagueStories %></span>
                <h2><%= t.latestNews %></h2>
            </div>
        </div>
        <% if (!blogs.length) { %>
            <div class="summary-card"><p class="mb-0 muted-copy"><%= t.noBlogs %></p></div>
        <% } else { %>
            <div class="card-grid">
                <% blogs.forEach(blog => { %>
                    <article class="story-card">
                        <% if (blog.imageUrl) { %>
                            <img src="<%= blog.imageUrl %>" alt="<%= blog.displayTitle %>" class="story-image">
                        <% } else { %>
                            <div class="story-image d-flex align-items-center justify-content-center text-muted fw-semibold"><%= t.siteName %></div>
                        <% } %>
                        <div class="story-body">
                            <div class="pill-row">
                                <span class="stat-pill"><%= new Date(blog.date).toLocaleDateString('en-IN') %></span>
                            </div>
                            <h3 class="h5 mb-3"><%= blog.displayTitle %></h3>
                            <p class="card-copy mb-0"><%= blog.displayDescription %></p>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </div>
</section>
<%- include('partials/footer') %>
