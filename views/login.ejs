<%- include('partials/head', { pageTitle: `${t.siteName} | ${t.loginTitle}`, bodyClass: 'auth-page' }) %>
<%- include('partials/navbar', { currentPath, user: null, isAdmin: false }) %>

<div class="container">
    <div class="auth-shell">
        <div class="auth-card">
            <div class="auth-header">
                <span class="section-kicker"><%= t.loginTitle %></span>
                <h1 class="h3 mb-2"><%= t.welcomeBack %></h1>
                <p class="mb-0 text-white-50"><%= t.siteTagline %></p>
            </div>
            <div class="auth-card-body">
                <form action="/login" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-semibold"><%= t.username %></label>
                        <input type="text" name="username" class="form-control form-control-lg" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold"><%= t.password %></label>
                        <input type="password" name="password" class="form-control form-control-lg" required>
                    </div>
                    <button class="btn btn-warning w-100 btn-lg rounded-pill fw-semibold"><%= t.loginTitle %></button>
                </form>
                <div class="auth-actions mt-4">
                    <a href="/signup" class="btn btn-outline-dark rounded-pill"><%= t.createAccount %></a>
                    <a href="/" class="btn btn-link text-decoration-none"><%= t.backHome %></a>
                </div>
            </div>
        </div>
    </div>
</div>
<%- include('partials/footer') %>
