<%- include('../partials/head', { pageTitle: `${t.siteName} | ${t.navAdmin}`, adminStyle: true }) %>

<section class="admin-shell">
    <div class="container">
        <div class="admin-hero">
            <div class="admin-hero-inner d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                    <span class="section-kicker"><%= t.navAdmin %></span>
                    <h1 class="h2 mb-2"><%= t.adminTitle %></h1>
                    <p class="mb-0 text-white-50"><%= t.adminSubtitle %></p>
                </div>
                <div class="admin-actions">
                    <a href="/" class="btn btn-light rounded-pill px-3"><%= t.adminViewSite %></a>
                    <a href="/logout" class="btn btn-outline-light rounded-pill px-3"><%= t.navLogout %></a>
                </div>
            </div>
        </div>

        <div class="admin-grid">
            <div class="admin-card">
                <h3 class="h4 mb-3"><%= t.addBlog %></h3>
                <p class="admin-note"><%= t.imageHelp %></p>
                <form action="/admin/blog/add" method="POST" enctype="multipart/form-data" class="row g-3 mt-1">
                    <div class="col-12">
                        <label class="form-label"><%= t.titleLabel %></label>
                        <input type="text" name="title" class="form-control" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label"><%= t.descriptionLabel %></label>
                        <textarea name="description" rows="3" class="form-control" required></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><%= t.imageUpload %></label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><%= t.imageUrl %></label>
                        <input type="url" name="imageUrl" class="form-control" placeholder="https://...">
                    </div>
                    <div class="col-12">
                        <button class="btn btn-warning rounded-pill px-4 w-100"><%= t.postBlog %></button>
                    </div>
                </form>
            </div>

            <div class="admin-card">
                <h3 class="h4 mb-3"><%= t.addMatch %></h3>
                <form action="/admin/match/add" method="POST" class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label"><%= t.chooseSeason %></label>
                        <input type="text" name="season" class="form-control" placeholder="GBPL 2026">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><%= t.venue %></label>
                        <input type="text" name="venue" class="form-control" placeholder="Ground / Venue">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><%= t.teamA %></label>
                        <input type="text" name="teamA" class="form-control" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><%= t.teamB %></label>
                        <input type="text" name="teamB" class="form-control" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><%= t.scoreA %></label>
                        <input type="text" name="scoreA" class="form-control" placeholder="145/6 (20)">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><%= t.scoreB %></label>
                        <input type="text" name="scoreB" class="form-control" placeholder="142/9 (20)">
                    </div>
                    <div class="col-12">
                        <label class="form-label"><%= t.resultLabel %></label>
                        <input type="text" name="result" class="form-control" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label"><%= t.detailsLabel %></label>
                        <textarea name="description" rows="3" class="form-control"></textarea>
                    </div>
                    <div class="col-12">
                        <button class="btn btn-primary rounded-pill px-4 w-100"><%= t.saveMatch %></button>
                    </div>
                </form>
            </div>
        </div>

        <div class="admin-grid">
            <div class="admin-card">
                <h3 class="h4 mb-3"><%= t.addPlayer %></h3>
                <form action="/admin/player/add" method="POST" class="row g-3">
                    <div class="col-12">
                        <label class="form-label"><%= t.playerName %></label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label"><%= t.matchesPlayed %></label>
                        <input type="number" name="matchesPlayed" class="form-control" value="0">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label"><%= t.runs %></label>
                        <input type="number" name="runs" class="form-control" value="0">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label"><%= t.wickets %></label>
                        <input type="number" name="wickets" class="form-control" value="0">
                    </div>
                    <div class="col-12">
                        <button class="btn btn-success rounded-pill px-4 w-100"><%= t.savePlayer %></button>
                    </div>
                </form>
            </div>

            <div class="admin-card p-0">
                <div class="p-4 pb-0">
                    <h3 class="h4 mb-3"><%= t.updatePlayers %></h3>
                </div>
                <div class="table-responsive px-3 pb-3">
                    <table class="table table-hover align-middle mb-0 admin-player-table">
                        <thead>
                            <tr>
                                <th><%= t.playerName %></th>
                                <th><%= t.matchesPlayed %></th>
                                <th><%= t.runs %></th>
                                <th><%= t.wickets %></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% players.forEach(player => { %>
                                <tr>
                                    <td data-label="<%= t.playerName %>"><strong><%= player.name %></strong></td>
                                    <td data-label="<%= t.matchesPlayed %>"><input type="number" form="update-<%= player._id %>" name="matchesPlayed" value="<%= player.matchesPlayed %>" class="form-control form-control-sm"></td>
                                    <td data-label="<%= t.runs %>"><input type="number" form="update-<%= player._id %>" name="runs" value="<%= player.runs %>" class="form-control form-control-sm"></td>
                                    <td data-label="<%= t.wickets %>"><input type="number" form="update-<%= player._id %>" name="wickets" value="<%= player.wickets %>" class="form-control form-control-sm"></td>
                                    <td class="text-end admin-player-actions" data-label="Actions">
                                        <form id="update-<%= player._id %>" action="/admin/player/update/<%= player._id %>" method="POST" class="d-inline">
                                            <button class="btn btn-primary btn-sm rounded-pill px-3"><%= t.saveChanges %></button>
                                        </form>
                                        <form action="/admin/player/delete/<%= player._id %>" method="POST" class="d-inline">
                                            <button class="btn btn-outline-danger btn-sm rounded-pill px-3"><%= t.deleteLabel %></button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="admin-grid">
            <div class="admin-table-shell">
                <div class="p-4 pb-2">
                    <h4 class="mb-0"><%= t.recentBlogs %></h4>
                </div>
                <ul class="admin-list">
                    <% if (!blogs.length) { %>
                        <li><span><%= t.blogEmptyAdmin %></span></li>
                    <% } %>
                    <% blogs.forEach(blog => { %>
                        <li>
                            <span><%= blog.title %></span>
                            <form action="/admin/blog/delete/<%= blog._id %>" method="POST">
                                <button class="btn btn-outline-danger btn-sm rounded-pill px-3"><%= t.deleteLabel %></button>
                            </form>
                        </li>
                    <% }) %>
                </ul>
            </div>
            <div class="admin-table-shell">
                <div class="p-4 pb-2">
                    <h4 class="mb-0"><%= t.recentMatchesAdmin %></h4>
                </div>
                <ul class="admin-list">
                    <% if (!matches.length) { %>
                        <li><span><%= t.matchEmptyAdmin %></span></li>
                    <% } %>
                    <% matches.forEach(match => { %>
                        <li>
                            <span><%= match.teamA %> vs <%= match.teamB %></span>
                            <form action="/admin/match/delete/<%= match._id %>" method="POST">
                                <button class="btn btn-outline-danger btn-sm rounded-pill px-3"><%= t.deleteLabel %></button>
                            </form>
                        </li>
                    <% }) %>
                </ul>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>

